{{- $index := slice -}}
{{- range .Site.Pages -}}
  {{- if and .Title (ne .Title "404") -}}
    {{- $text := .Plain | htmlUnescape | truncate 500 -}}
    {{- if not $text }}{{ $text = .Description | htmlUnescape }}{{ end -}}
    {{- if $text -}}
      {{- $index = $index | append (dict "title" .Title "url" .RelPermalink "description" (.Description | htmlUnescape) "content" $text) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $index | jsonify -}}
