{{- $pages := where .Site.RegularPages "Section" "w" -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }} — Blog</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>Blog posts and notes from {{ .Site.Title }}</description>
    <generator>Hugo</generator>
    <language>en-us</language>
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml"/>
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Plain | htmlUnescape | truncate 500 }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
